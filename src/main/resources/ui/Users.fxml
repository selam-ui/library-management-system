<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12" prefWidth="900" prefHeight="600" styleClass="root-pane"
      xmlns:fx="http://javafx.com/fxml" fx:controller="controller.UserController">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>
    <Label text="User Management" styleClass="title"/>

    <GridPane hgap="10" vgap="10">
        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Password:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <PasswordField fx:id="passwordField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>

        <Label text="Full Name:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="fullNameField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Email:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <TextField fx:id="emailField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>

        <Label text="Role:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="roleComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="Add" onAction="#onAdd" styleClass="primary"/>
        <Button text="Update" onAction="#onUpdate"/>
        <Button text="Delete" onAction="#onDelete"/>
        <Button text="Approve" onAction="#onApprove"/>
        <Button text="Activate" onAction="#onActivate"/>
        <Button text="Deactivate" onAction="#onDeactivate"/>
        <Button text="Clear" onAction="#onClear"/>
        <Button text="Back" onAction="#onBack"/>
    </HBox>

    <TableView fx:id="table" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
            <TableColumn fx:id="usernameCol" text="Username" prefWidth="140"/>
            <TableColumn fx:id="passwordCol" text="Password" prefWidth="300"/>
            <TableColumn fx:id="fullNameCol" text="Full Name" prefWidth="170"/>
            <TableColumn fx:id="emailCol" text="Email" prefWidth="180"/>
            <TableColumn fx:id="roleCol" text="Role" prefWidth="100"/>
            <TableColumn fx:id="approvedCol" text="Approved" prefWidth="80"/>
            <TableColumn fx:id="activeCol" text="Active" prefWidth="80"/>
        </columns>
    </TableView>

    <Label fx:id="messageLabel" styleClass="message"/>
</VBox>
